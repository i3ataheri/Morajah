---
interface Props {
  title: string;
  subtitle?: string;
  showBack?: boolean;
}

const { title, subtitle, showBack = false } = Astro.props;
---

<header class="site-header">
  <div class="header-bg">
    <div class="header-shape shape-1"></div>
    <div class="header-shape shape-2"></div>
    <div class="header-shape shape-3"></div>
  </div>

  <div class="header-content container">
    {showBack && (
      <a href="/" class="back-btn">
        العودة
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </a>
    )}

    <div class="header-icon">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
        <rect x="9" y="3" width="6" height="4" rx="1"/>
        <path d="M9 14l2 2 4-4"/>
      </svg>
    </div>

    <h1 class="header-title">{title}</h1>
    {subtitle && <p class="header-subtitle">{subtitle}</p>}
  </div>

  <div class="wave-container">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
      <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="#f0fdfa"/>
      <path d="M0,80 C240,140 480,20 720,80 C960,140 1200,20 1440,80 L1440,120 L0,120 Z" fill="#f0fdfa" opacity="0.5"/>
    </svg>
  </div>
</header>

<style lang="scss">
  .site-header {
    position: relative;
    background: linear-gradient(135deg, #0d9488 0%, #0f766e 50%, #115e59 100%);
    color: white;
    padding: 50px 20px 100px;
    text-align: center;
    overflow: hidden;
  }

  .header-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .header-shape {
    position: absolute;
    border-radius: 50%;
    opacity: 0.08;
    background: white;
  }

  .shape-1 {
    width: 300px;
    height: 300px;
    top: -80px;
    left: -60px;
    animation: float 8s ease-in-out infinite;
  }

  .shape-2 {
    width: 200px;
    height: 200px;
    bottom: -40px;
    right: -30px;
    animation: float 6s ease-in-out infinite reverse;
  }

  .shape-3 {
    width: 150px;
    height: 150px;
    top: 20%;
    right: 30%;
    animation: float 10s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(-5deg); }
  }

  .header-content {
    position: relative;
    z-index: 2;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 20px;
    padding: 6px 14px;
    border-radius: 8px;
    transition: var(--transition);

    &:hover {
      background: rgba(255, 255, 255, 0.15);
      color: white;
    }
  }

  .header-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .header-title {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 8px;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.15);
  }

  .header-subtitle {
    font-size: 15px;
    opacity: 0.9;
    font-weight: 400;
  }

  .wave-container {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 1;

    svg {
      display: block;
      width: 100%;
      height: 60px;
    }
  }

  @media (max-width: 640px) {
    .site-header {
      padding: 40px 16px 80px;
    }

    .header-title {
      font-size: 22px;
    }

    .header-icon {
      width: 64px;
      height: 64px;

      svg {
        width: 32px;
        height: 32px;
      }
    }
  }
</style>
