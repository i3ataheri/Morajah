---
interface Props {
  member: {
    id: string;
    name: string;
    status?: string;
  };
  isReadOnly?: boolean;
}

const { member, isReadOnly = false } = Astro.props;
---

<div class="member-row" data-member-id={member.id} data-status={member.status || ''}>
  <div class="member-info">
    <div class="member-avatar">
      {member.name.charAt(0)}
    </div>
    <span class="member-name">{member.name}</span>
  </div>

  {!isReadOnly && (
    <div class="status-buttons">
      <button
        class="status-btn present"
        data-status="present"
        title="حاضر"
        aria-label="حاضر"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </button>

      <button
        class="status-btn absent"
        data-status="absent"
        title="غایب"
        aria-label="غایب"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="15" y1="9" x2="9" y2="15"/>
          <line x1="9" y1="9" x2="15" y2="15"/>
        </svg>
      </button>

      <button
        class="status-btn excused"
        data-status="excused"
        title="عذر موجه"
        aria-label="عذر موجه"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
      </button>

      <button
        class="status-btn new-member"
        data-status="new_member"
        title="عضو جدید"
        aria-label="عضو جدید"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="8.5" cy="7" r="4"/>
          <line x1="20" y1="8" x2="20" y2="14"/>
          <line x1="23" y1="11" x2="17" y2="11"/>
        </svg>
      </button>
    </div>
  )}

  {isReadOnly && member.status && (
    <div class={`status-badge ${member.status}`}>
      {member.status === 'present' && 'حاضر'}
      {member.status === 'absent' && 'غایب'}
      {member.status === 'excused' && 'عذر موجه'}
      {member.status === 'new_member' && 'جدید'}
    </div>
  )}
</div>

<style lang="scss">
  .member-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: white;
    padding: 16px 20px;
    margin-bottom: 10px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    transition: var(--transition);

    &:hover {
      box-shadow: var(--shadow-lg);
      transform: translateY(-1px);
    }

    &.status-set {
      border-color: var(--primary-light);
      background: linear-gradient(135deg, #f0fdfa, #ffffff);
    }
  }

  .member-info {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .member-avatar {
    width: 44px;
    height: 44px;
    border-radius: 14px;
    background: var(--primary-gradient);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .member-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
  }

  .status-buttons {
    display: flex;
    gap: 8px;
  }

  .status-btn {
    width: 44px;
    height: 44px;
    border: 2px solid transparent;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    background: #f1f5f9;

    &:hover {
      transform: scale(1.1);
    }

    &:active {
      transform: scale(0.95);
    }

    &.present {
      color: #16a34a;
      &:hover, &.active {
        background: #dcfce7;
        border-color: #16a34a;
      }
    }

    &.absent {
      color: #dc2626;
      &:hover, &.active {
        background: #fee2e2;
        border-color: #dc2626;
      }
    }

    &.excused {
      color: #ea580c;
      &:hover, &.active {
        background: #fff7ed;
        border-color: #ea580c;
      }
    }

    &.new-member {
      color: #2563eb;
      &:hover, &.active {
        background: #eff6ff;
        border-color: #2563eb;
      }
    }
  }

  .status-badge {
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;

    &.present {
      background: #dcfce7;
      color: #16a34a;
    }

    &.absent {
      background: #fee2e2;
      color: #dc2626;
    }

    &.excused {
      background: #fff7ed;
      color: #ea580c;
    }

    &.new_member {
      background: #eff6ff;
      color: #2563eb;
    }
  }

  @media (max-width: 640px) {
    .member-row {
      padding: 14px 16px;
      flex-direction: column;
      gap: 12px;
    }

    .status-buttons {
      width: 100%;
      justify-content: center;
    }

    .status-btn {
      width: 48px;
      height: 48px;
    }
  }
</style>
